#ifndef LORE_TOOLS_HLR_FILE_CONTEXT_H_IN
#define LORE_TOOLS_HLR_FILE_CONTEXT_H_IN

//===----------------------------------------------------------------------===//
// File Context Declarations

#define __LORE_PRIV__   __attribute__((visibility("hidden")))
#define __LORE_EXPORT__ __attribute__((visibility("default")))

#define __LORE_LIKELY__(EXPR)   __builtin_expect(!!(EXPR), 1)
#define __LORE_UNLIKELY__(EXPR) __builtin_expect(!!(EXPR), 0)

#define __LORE_OFFSET_OF__(TYPE, MEMBER) __builtin_offsetof(TYPE, MEMBER)

#define __LORE_FUNC_TYPE__(EXPR)                                                                   \
    __typeof__(({                                                                                  \
        __auto_type __tmp = (EXPR);                                                                \
        __tmp;                                                                                     \
    }))

#ifdef _WIN32
typedef unsigned long long __LORE_SIZE_T__;
#else
typedef unsigned long __LORE_SIZE_T__;
#endif

#define __LORE_MAGIC_SIGN__ 0x1234567890ABCDEFULL

struct LoreThunkProcInfo {
    const char *signature;
    void **pTramp;
};

struct LoreFunctionTrampoline {
    void *saved_function;
    char thunk_instr[16];
    __LORE_SIZE_T__ magic_sign;
};

struct LoreFunctionDecayGuard {
    void *hostAddr;
    void *guestTramp;
};

struct LoreFunctionDecayGuardInfo {
    const char *signature;
    int count;
    struct LoreFunctionDecayGuard **pProcs;
};

struct LoreRuntimeContext {
    void *pthread_create;
    void *pthread_exit;
};

struct LoreFileContext {
    struct LoreRuntimeContext *runtimeContext;

    void *emuAddr;
    void (*setThreadCallback)(void *);

    // Callback check guards
    struct LoreThunkProcInfo *CCGs;

    // Function decay guards
    struct LoreFunctionDecayGuardInfo *FDGs;
};

#define __LORE_THUNK_INSTR_OFFSET__ __LORE_OFFSET_OF__(struct LoreFunctionTrampoline, thunk_instr)

extern __LORE_PRIV__ struct LoreFileContext LoreFileContext_instance;

static inline void *__LoreFileContext_CCG(void *addr, void *tramp) {
    if (__LORE_UNLIKELY__((__LORE_SIZE_T__) addr <
                          (__LORE_SIZE_T__) LoreFileContext_instance.emuAddr)) {
        struct LoreFunctionTrampoline *maybeGuestTramp =
            (struct LoreFunctionTrampoline *) ((char *) addr - __LORE_THUNK_INSTR_OFFSET__);
        if (__LORE_UNLIKELY__(maybeGuestTramp->magic_sign == __LORE_MAGIC_SIGN__)) {
            addr = maybeGuestTramp->saved_function;
        } else {
            LoreFileContext_instance.setThreadCallback(addr);
            addr = tramp;
        }
    }
    return addr;
}

#define LORE_CCG_DECL(NUM) extern __LORE_PRIV__ void *LoreFileContext_CCG_Tramp_##NUM;
#define LORE_FDG_DECL(NUM1, NUM2)                                                                  \
    extern __LORE_PRIV__ struct LoreFunctionDecayGuard LoreFileContext_FDG_Proc_##NUM1##_##NUM2;
#define LORE_CCG_IMPL(NUM) __LORE_PRIV__ void *LoreFileContext_CCG_Tramp_##NUM = 0;
#define LORE_FDG_IMPL(NUM1, NUM2, FUNC)                                                            \
    __LORE_PRIV__ struct LoreFunctionDecayGuard LoreFileContext_FDG_Proc_##NUM1##_##NUM2 = {       \
        .hostAddr = (void *) &FUNC,                                                                \
        .guestTramp = 0,                                                                           \
    };

#define LORE_CCG_GET(NUM, EXPR)                                                                    \
    ((__LORE_FUNC_TYPE__(EXPR)) __LoreFileContext_CCG((void *) (EXPR),                             \
                                                      LoreFileContext_CCG_Tramp_##NUM))
#define LORE_FDG_GET(NUM1, NUM2, EXPR)                                                             \
    ((__LORE_FUNC_TYPE__(EXPR)) LoreFileContext_FDG_Proc_##NUM1##_##NUM2.guestTramp)
//===----------------------------------------------------------------------===//





//===----------------------------------------------------------------------===//
// Generated common header
LORE_CCG_DECL(1)
LORE_CCG_DECL(2)

LORE_FDG_DECL(1, 1)
LORE_FDG_DECL(2, 1)

#define LORE_CCG_1(X) LORE_CCG_GET(1, (X))
#define LORE_CCG_2(X) LORE_CCG_GET(2, (X))

#define LORE_FDG_1_1(X) LORE_FDG_GET(1, 1, (X))
#define LORE_FDG_2_1(X) LORE_FDG_GET(2, 1, (X))
//===----------------------------------------------------------------------===//




//===----------------------------------------------------------------------===//
// Generated single source
LORE_CCG_IMPL(1)
LORE_CCG_IMPL(2)

static struct LoreThunkProcInfo LoreFileContext_CCGs[] = {
    {.signature = "int (*)(int, int)", .pTramp = &LoreFileContext_CCG_Tramp_1},
    {.signature = "void (*)()",        .pTramp = &LoreFileContext_CCG_Tramp_2},
};

static struct LoreFunctionDecayGuard *LoreFileContext_FDG_Proc_1_instances[] = {
    &LoreFileContext_FDG_Proc_1_1,
};

static struct LoreFunctionDecayGuard *LoreFileContext_FDG_Proc_2_instances[] = {
    &LoreFileContext_FDG_Proc_2_1,
};

static struct LoreFunctionDecayGuardInfo LoreFileContext_FDGs[] = {
    {"int (*)(int, int)", 1, LoreFileContext_FDG_Proc_1_instances},
    {"void (*)()",        1, LoreFileContext_FDG_Proc_2_instances},
};

__LORE_PRIV__ struct LoreFileContext LoreFileContext_instance = {
    .runtimeContext = 0,
    .emuAddr = 0,
    .setThreadCallback = 0,
    .CCGs = LoreFileContext_CCGs,
    .FDGs = LoreFileContext_FDGs,
};

__LORE_EXPORT__ struct LoreFileContext *__getLoreFileContext() {
    return &LoreFileContext_instance;
}
//===----------------------------------------------------------------------===//




//===----------------------------------------------------------------------===//
// File including callback check guards
static void some_method(int (*op)(int, int)) {
    int x, y, z;
    z = op(x, y);

    // change to
    z = LORE_CCG_1(op)(x, y);
}
//===----------------------------------------------------------------------===//




//===----------------------------------------------------------------------===//
// File including function decay guards
static int func1(int a, int b) {
    return a + b;
}
static void func2() {
}

static void some_method_2() {
    void (*f)();
    f = func2;

    // change to
    f = LORE_FDG_2_1(func2);
}

// Append to end
LORE_FDG_IMPL(1, 1, func1)
LORE_FDG_IMPL(2, 1, func2)
//===----------------------------------------------------------------------===//

#endif // LORE_TOOLS_HLR_FILE_CONTEXT_H_IN
